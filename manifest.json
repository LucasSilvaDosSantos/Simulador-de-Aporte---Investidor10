{
  "manifest_version": 3,
  "name": "Rebalanceador de Carteira - Investidor10",
  "version": "1.0",
  "description": "Simula o aporte ideal para rebalancear sua carteira",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Simular Aporte"
  },

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://investidor10.com.br/*"
  ]
}
